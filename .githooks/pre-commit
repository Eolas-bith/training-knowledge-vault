#!/usr/bin/env bash
# Vault structural-integrity gate. Enable once per clone:
#   git config core.hooksPath .githooks
# Blocks a commit if vault-doctor finds structural errors.
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
if command -v python3 >/dev/null 2>&1; then
  python3 "$ROOT/97-scripts/vault-doctor.py" --root "$ROOT" || {
    echo ""
    echo "vault-doctor found structural errors — commit blocked."
    echo "Fix them, or bypass once with: git commit --no-verify"
    exit 1
  }
fi
